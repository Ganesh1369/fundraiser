// Prisma schema — ICE Fundraiser Platform
//
// This file is the source of truth for the database schema going forward.
// Phase 1 code continues to use mysql2 with raw SQL; new Phase 2 code uses @prisma/client.
// Migrations live in prisma/migrations/ and are applied via `prisma migrate deploy`.
//
// To regenerate the client:           npx prisma generate
// To create a new migration:          npx prisma migrate dev --name <description> --create-only
// To apply pending migrations:        npx prisma migrate deploy
// To mark an existing DB as baselined: npx prisma migrate resolve --applied "0_init"

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["views"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ===== Enums =====

enum UserType {
  student
  individual
  organization
}

enum Gender {
  male
  female
  other
}

enum ExperienceLevel {
  beginner
  intermediate
  advanced
}

enum DonationPurpose {
  donation
  registration_fee
  csr_donation
}

enum CertificateStatus {
  pending
  processing
  approved
  rejected
}

enum CertificateType {
  G80   @map("80g")
  csr_receipt
}

enum RegistrationStatus {
  registered
  cancelled
}

enum OrgSettingType {
  text
  image
  date
  number
}

// ===== Tables =====

model User {
  id                    String   @id @default(dbgenerated("(UUID())")) @db.Char(36)
  user_type             UserType
  name                  String   @db.VarChar(100)
  age                   Int?
  email                 String   @unique(map: "email") @db.VarChar(255)
  phone                 String   @db.VarChar(20)
  password_hash         String   @db.VarChar(255)
  class_grade           String?  @db.VarChar(50)
  school_name           String?  @db.VarChar(200)
  address_line_1        String?  @db.VarChar(255)
  address_line_2        String?  @db.VarChar(255)
  area                  String?  @db.VarChar(100)
  city                  String?  @db.VarChar(100)
  state                 String?  @db.VarChar(100)
  pincode               String?  @db.VarChar(10)
  country               String?  @default("India") @db.VarChar(100)
  organization_name     String?  @db.VarChar(200)
  pan_number            String?  @db.VarChar(20)
  pan_document_url      String?  @db.VarChar(500)
  referral_code         String   @unique(map: "referral_code") @db.VarChar(20)
  referred_by           String?  @db.Char(36)
  referral_points       Int      @default(0)
  profile_pic           String?  @db.VarChar(500)
  email_verified        Boolean  @default(false)
  registration_fee_paid Boolean  @default(false)
  is_active             Boolean  @default(true)
  enrolled_via_event_id String?  @db.Char(36)
  created_at            DateTime @default(now()) @db.DateTime(0)
  updated_at            DateTime @default(now()) @updatedAt @db.DateTime(0)

  referrer                User?                   @relation("Referrals", fields: [referred_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "users_ibfk_1")
  enrolled_via_event      Event?                  @relation("UserEnrolledVia", fields: [enrolled_via_event_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_users_enrolled_via")
  referred_users          User[]                  @relation("Referrals")
  donations               Donation[]              @relation("DonationOwner")
  donations_as_referrer   Donation[]              @relation("DonationReferrer")
  certificate_requests    CertificateRequest[]
  event_registrations     EventRegistration[]
  push_subscription       PushSubscription?
  referral_points_history ReferralPointsHistory[]

  @@index([referral_code], map: "idx_users_referral_code")
  @@index([referred_by], map: "idx_users_referred_by")
  @@index([user_type], map: "idx_users_user_type")
  @@index([email], map: "idx_users_email")
  @@index([enrolled_via_event_id], map: "idx_users_enrolled_via")
  @@map("users")
}

model Event {
  id                String   @id @default(dbgenerated("(UUID())")) @db.Char(36)
  project_id        String?  @db.Char(36)
  event_name        String   @db.VarChar(150)
  event_type        String   @db.VarChar(50)
  event_date        DateTime @db.Date
  event_location    String   @db.VarChar(200)
  total_cost        Decimal? @db.Decimal(15, 2)
  description       String?  @db.Text
  banner_url        String?  @db.VarChar(500)
  hero_banner_url   String?  @db.VarChar(500)
  schedule          String?  @db.Text
  venue_details     String?  @db.Text
  contact_name      String?  @db.VarChar(100)
  contact_phone     String?  @db.VarChar(20)
  contact_email     String?  @db.VarChar(255)
  registration_open Boolean  @default(true)
  is_active         Boolean  @default(true)
  created_at        DateTime @default(now()) @db.DateTime(0)
  updated_at        DateTime @default(now()) @updatedAt @db.DateTime(0)

  project             Project?            @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_events_project")
  donations           Donation[]
  event_registrations EventRegistration[]
  enrolled_users      User[]               @relation("UserEnrolledVia")

  @@index([is_active], map: "idx_events_is_active")
  @@index([registration_open], map: "idx_events_registration_open")
  @@index([project_id], map: "idx_events_project_id")
  @@map("events")
}

model EventRegistration {
  id                             String             @id @default(dbgenerated("(UUID())")) @db.Char(36)
  event_id                       String             @db.Char(36)
  user_id                        String             @db.Char(36)
  date_of_birth                  DateTime           @db.Date
  gender                         Gender
  blood_group                    String?            @db.VarChar(5)
  emergency_contact_name         String?            @db.VarChar(100)
  emergency_contact_phone        String?            @db.VarChar(20)
  emergency_contact_relationship String?            @db.VarChar(50)
  experience_level               ExperienceLevel
  medical_conditions             String?            @db.Text
  allergies                      String?            @db.Text
  on_medication                  Boolean            @default(false)
  address_line_1                 String?            @db.VarChar(255)
  address_line_2                 String?            @db.VarChar(255)
  city                           String?            @db.VarChar(100)
  state                          String?            @db.VarChar(100)
  pin_code                       String?            @db.VarChar(20)
  country                        String?            @default("India") @db.VarChar(100)
  fitness_declaration            Boolean            @default(false)
  terms_accepted                 Boolean            @default(true)
  registration_status            RegistrationStatus @default(registered)
  created_at                     DateTime           @default(now()) @db.DateTime(0)

  event Event @relation(fields: [event_id], references: [id], onDelete: Cascade, map: "event_registrations_ibfk_1")
  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "event_registrations_ibfk_2")

  @@unique([event_id, user_id], map: "idx_event_registrations_unique")
  @@index([event_id], map: "idx_event_registrations_event_id")
  @@index([user_id], map: "idx_event_registrations_user_id")
  @@index([registration_status], map: "idx_event_registrations_status")
  @@map("event_registrations")
}

model Donation {
  id                     String          @id @default(dbgenerated("(UUID())")) @db.Char(36)
  user_id                String          @db.Char(36)
  event_id               String?         @db.Char(36)
  project_id             String?         @db.Char(36)
  amount                 Decimal         @db.Decimal(12, 2)
  currency               String?         @default("INR") @db.VarChar(3)
  num_trees              Int?            @db.UnsignedInt
  razorpay_order_id      String?         @db.VarChar(100)
  razorpay_payment_id    String?         @db.VarChar(100)
  razorpay_signature     String?         @db.VarChar(255)
  status                 String?         @default("pending") @db.VarChar(20)
  referrer_id            String?         @db.Char(36)
  points_awarded         Boolean         @default(false)
  points_formula_version Int             @default(2) @db.UnsignedTinyInt
  purpose                DonationPurpose @default(donation)
  csr_reference_number   String?         @db.VarChar(50)
  request_80g            Boolean         @default(false)
  payment_method         String?         @db.VarChar(50)
  created_at             DateTime        @default(now()) @db.DateTime(0)
  updated_at             DateTime        @default(now()) @updatedAt @db.DateTime(0)

  user                    User                    @relation("DonationOwner", fields: [user_id], references: [id], onDelete: Cascade, map: "donations_ibfk_1")
  event                   Event?                  @relation(fields: [event_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "donations_ibfk_2")
  referrer                User?                   @relation("DonationReferrer", fields: [referrer_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "donations_ibfk_3")
  project                 Project?                @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_donations_project")
  certificate_request     CertificateRequest?
  referral_points_history ReferralPointsHistory[]

  @@index([user_id], map: "idx_donations_user_id")
  @@index([event_id], map: "idx_donations_event_id")
  @@index([referrer_id], map: "idx_donations_referrer_id")
  @@index([created_at], map: "idx_donations_created_at")
  @@index([status], map: "idx_donations_status")
  @@index([project_id], map: "idx_donations_project_id")
  @@index([purpose, project_id], map: "idx_donations_purpose_project")
  @@map("donations")
}

model ReferralPointsHistory {
  id            String   @id @default(dbgenerated("(UUID())")) @db.Char(36)
  user_id       String   @db.Char(36)
  donation_id   String   @db.Char(36)
  points_earned Int
  donor_name    String?  @db.VarChar(100)
  created_at    DateTime @default(now()) @db.DateTime(0)

  user     User     @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "referral_points_history_ibfk_1")
  donation Donation @relation(fields: [donation_id], references: [id], onDelete: Cascade, map: "referral_points_history_ibfk_2")

  @@index([user_id], map: "idx_referral_points_user_id")
  @@index([donation_id], map: "donation_id")
  @@map("referral_points_history")
}

model CertificateRequest {
  id                    String            @id @default(dbgenerated("(UUID())")) @db.Char(36)
  user_id               String            @db.Char(36)
  donation_id           String?           @unique(map: "idx_certificate_requests_donation") @db.Char(36)
  type                  CertificateType   @default(G80)
  pan_number            String            @db.VarChar(20)
  status                CertificateStatus @default(pending)
  admin_notes           String?           @db.Text
  certificate_url       String?           @db.VarChar(500)
  certificate_number    String?           @unique(map: "idx_certificate_requests_number") @db.VarChar(50)
  pdf_url               String?           @db.VarChar(500)
  auto_generated        Boolean           @default(false)
  generation_attempts   Int               @default(0)
  last_generation_error String?           @db.Text
  issued_at             DateTime?         @db.DateTime(0)
  requested_at          DateTime          @default(now()) @db.DateTime(0)
  processed_at          DateTime?         @db.DateTime(0)
  created_at            DateTime          @default(now()) @db.DateTime(0)
  updated_at            DateTime          @default(now()) @updatedAt @db.DateTime(0)

  user     User      @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "certificate_requests_ibfk_1")
  donation Donation? @relation(fields: [donation_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "certificate_requests_ibfk_2")

  @@index([user_id], map: "idx_certificate_requests_user_id")
  @@index([status], map: "idx_certificate_requests_status")
  @@index([type], map: "idx_certificate_requests_type")
  @@map("certificate_requests")
}

model AdminUser {
  id            String   @id @default(dbgenerated("(UUID())")) @db.Char(36)
  username      String   @unique(map: "username") @db.VarChar(50)
  password_hash String   @db.VarChar(255)
  name          String?  @db.VarChar(100)
  email         String?  @db.VarChar(255)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now()) @db.DateTime(0)
  updated_at    DateTime @default(now()) @updatedAt @db.DateTime(0)

  @@map("admin_users")
}

model PushSubscription {
  id         String   @id @default(dbgenerated("(UUID())")) @db.Char(36)
  user_id    String   @unique(map: "unique_push_user") @db.Char(36)
  endpoint   String   @db.Text
  p256dh     String   @db.VarChar(255)
  auth       String   @db.VarChar(255)
  created_at DateTime @default(now()) @db.DateTime(0)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "push_subscriptions_ibfk_1")

  @@index([user_id], map: "idx_push_subscriptions_user_id")
  @@map("push_subscriptions")
}

model OtpVerification {
  id         String   @id @default(dbgenerated("(UUID())")) @db.Char(36)
  email      String   @db.VarChar(255)
  otp        String   @db.VarChar(10)
  purpose    String   @default("register") @db.VarChar(20)
  verified   Boolean  @default(false)
  expires_at DateTime @db.DateTime(0)
  created_at DateTime @default(now()) @db.DateTime(0)

  @@index([email], map: "idx_otp_verifications_email")
  @@index([email, purpose], map: "idx_otp_verifications_email_purpose")
  @@map("otp_verifications")
}

// ===== Phase 2.1 — Org Settings =====
//
// Single key-value table holding ICE legal name, address, PAN, 80G info,
// signatory + signature image, logo. Admin-editable via /admin/settings.
// PDF certificate generation reads at generation time.

model OrgSetting {
  setting_key   String         @id @db.VarChar(100)
  setting_value String?        @db.Text
  setting_type  OrgSettingType @default(text)
  label         String?        @db.VarChar(150)
  is_required   Boolean        @default(false)
  updated_at    DateTime       @default(now()) @updatedAt @db.DateTime(0)
  updated_by    String?        @db.Char(36)

  @@map("org_settings")
}

// ===== Phase 2.1 — Projects =====
//
// First-class projects (initial seed: ROOTS, ZOO). Public landing pages render from DB on every request.
// Events and donations gain project_id FKs in a follow-up migration (Day 2).

model Project {
  id            String   @id @default(dbgenerated("(UUID())")) @db.Char(36)
  slug          String   @unique(map: "slug") @db.VarChar(100)
  name          String   @db.VarChar(150)
  tagline       String?  @db.VarChar(255)
  logo_url      String?  @db.VarChar(500)
  description   String?  @db.Text
  vision        String?  @db.Text
  mission       String?  @db.Text
  banner_urls   Json?
  display_order Int      @default(0)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now()) @db.DateTime(0)
  updated_at    DateTime @default(now()) @updatedAt @db.DateTime(0)

  accomplishments Accomplishment[]
  events          Event[]
  donations       Donation[]

  @@index([is_active], map: "idx_projects_is_active")
  @@index([slug], map: "idx_projects_slug")
  @@map("projects")
}

model Accomplishment {
  id            String   @id @default(dbgenerated("(UUID())")) @db.Char(36)
  project_id    String   @db.Char(36)
  title         String   @db.VarChar(200)
  description   String?  @db.Text
  metric_value  String?  @db.VarChar(50)
  metric_unit   String?  @db.VarChar(50)
  icon          String?  @db.VarChar(50)
  display_order Int      @default(0)
  created_at    DateTime @default(now()) @db.DateTime(0)
  updated_at    DateTime @default(now()) @updatedAt @db.DateTime(0)

  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade, map: "accomplishments_ibfk_1")

  @@index([project_id], map: "idx_accomplishments_project_id")
  @@map("accomplishments")
}

// Phase 2.2 Day 1 — CSR partnerships shown as a carousel on the user dashboard.
// Admin-managed via /api/admin/csr; public list at /api/csr/active.
model CorporateProfile {
  user_id                          String   @id @db.Char(36)
  cin                              String?  @db.VarChar(21)
  gstin                            String?  @db.VarChar(15)
  csr_registration_number          String?  @db.VarChar(50)
  incorporated_year                Int?     @db.SmallInt
  industry                         String?  @db.VarChar(100)
  logo_url                         String?  @db.VarChar(500)
  authorized_signatory_name        String?  @db.VarChar(150)
  authorized_signatory_designation String?  @db.VarChar(150)
  authorized_signatory_email       String?  @db.VarChar(255)
  authorized_signatory_phone       String?  @db.VarChar(20)
  created_at                       DateTime @default(now()) @db.DateTime(0)
  updated_at                       DateTime @default(now()) @updatedAt @db.DateTime(0)

  @@index([cin],   map: "idx_corporate_profiles_cin")
  @@index([gstin], map: "idx_corporate_profiles_gstin")
  @@map("corporate_profiles")
}

model CsrActivity {
  id              String   @id @default(dbgenerated("(UUID())")) @db.Char(36)
  title           String   @db.VarChar(200)
  subtitle        String?  @db.VarChar(255)
  partner_name    String?  @db.VarChar(150)
  logo_url        String?  @db.VarChar(500)
  hero_image_url  String?  @db.VarChar(500)
  summary         String?  @db.Text
  link_url        String?  @db.VarChar(500)
  display_order   Int      @default(0)
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now()) @db.DateTime(0)
  updated_at      DateTime @default(now()) @updatedAt @db.DateTime(0)

  @@index([is_active], map: "idx_csr_activities_is_active")
  @@index([display_order], map: "idx_csr_activities_display_order")
  @@map("csr_activities")
}

// Phase 2.2 — multi-tranche CSR pledges. A header row + N scheduled tranches.
// Each tranche links to a donations row once paid; receipts are issued per
// tranche through the existing certificate_requests pipeline.
model CsrCommitment {
  id                    String    @id @default(dbgenerated("(UUID())")) @db.Char(36)
  user_id               String    @db.Char(36)
  project_id            String?   @db.Char(36)
  total_amount          Decimal   @db.Decimal(15, 2)
  currency              String    @default("INR") @db.VarChar(3)
  period_label          String?   @db.VarChar(20)
  notes                 String?   @db.Text
  status                CsrCommitmentStatus @default(active)
  created_by_admin_id   String?   @db.Char(36)
  created_at            DateTime  @default(now()) @db.DateTime(0)
  updated_at            DateTime  @default(now()) @updatedAt @db.DateTime(0)

  @@index([user_id],    map: "idx_csr_commitments_user")
  @@index([project_id], map: "idx_csr_commitments_project")
  @@index([status],     map: "idx_csr_commitments_status")
  @@map("csr_commitments")
}

model CsrCommitmentTranche {
  id              String    @id @default(dbgenerated("(UUID())")) @db.Char(36)
  commitment_id   String    @db.Char(36)
  sequence        Int       @db.SmallInt
  planned_amount  Decimal   @db.Decimal(15, 2)
  planned_date    DateTime? @db.Date
  donation_id     String?   @db.Char(36)
  status          CsrTrancheStatus @default(scheduled)
  paid_at         DateTime? @db.DateTime(0)
  notes           String?   @db.VarChar(255)
  created_at      DateTime  @default(now()) @db.DateTime(0)
  updated_at      DateTime  @default(now()) @updatedAt @db.DateTime(0)

  @@unique([commitment_id, sequence], map: "uniq_tranche_seq_per_commitment")
  @@index([commitment_id], map: "idx_csr_tranches_commitment")
  @@index([donation_id],   map: "idx_csr_tranches_donation")
  @@index([status],        map: "idx_csr_tranches_status")
  @@map("csr_commitment_tranches")
}

enum CsrCommitmentStatus {
  active
  completed
  cancelled
}

enum CsrTrancheStatus {
  scheduled
  paid
  skipped
}

// ===== Views =====
// Both views are pre-existing in prod; included so Prisma introspection stays in sync.
// They are read-only from the application.

view Leaderboard {
  id              String   @unique @db.Char(36)
  name            String   @db.VarChar(100)
  email           String   @db.VarChar(255)
  city            String?  @db.VarChar(100)
  user_type       UserType
  referral_points Int
  total_donations Decimal  @db.Decimal(34, 2)
  donation_count  Decimal  @db.Decimal(22, 0)
  score           Decimal  @db.Decimal(35, 2)

  @@map("leaderboard")
}

view LeaderboardView {
  id              String  @unique @db.Char(36)
  name            String  @db.VarChar(100)
  email           String  @db.VarChar(255)
  phone           String  @db.VarChar(20)
  referral_code   String  @db.VarChar(20)
  referral_points Int
  total_donations Decimal @db.Decimal(34, 2)
  donation_count  Decimal @db.Decimal(22, 0)
  total_trees     Decimal @db.Decimal(32, 0)
  score           Decimal @db.Decimal(35, 2)

  @@map("leaderboard_view")
}
